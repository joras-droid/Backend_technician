generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  firstName String
  lastName  String
  email     String   @unique
  phone     String?
  address   String?

  username      String   @unique
  password      String   // hashed
  profileImageUrl String? // S3 URL for profile image

  role        UserRole
  whitelisted Boolean  @default(false) // Only whitelisted emails can signup/signin

  workOrdersAssigned WorkOrder[] @relation("AssignedTechnician")
  timeEntries        TimeEntry[]
  auditLogs          AuditLog[]  @relation("AuditActor")
  notifications      Notification[]
  timeEntryEdits     TimeEntryEdit[] @relation("AuditActor")
}

enum UserRole {
  ADMIN
  MANAGER
  TECHNICIAN
}

model Client {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  name      String
  email     String?
  phone     String?
  address   String?
  notes     String?

  workOrders WorkOrder[]
}

model WorkOrderTemplate {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  name      String
  tasks     String?  // JSON or newline-delimited
  notes     String?

  workOrders WorkOrder[]
}

model WorkOrder {
  id            String            @id @default(cuid())
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  workOrderNumber String          @unique
  scheduledAt     DateTime
  estimatedHours  Float?
  payRate         Float?

  facilityName    String
  facilityAddress String
  pointOfContact  String?
  tasks           String?
  notes           String?

  status          WorkOrderStatus @default(ACTIVE)
  invoiceNumber   String?

  clientId        String?
  client          Client?         @relation(fields: [clientId], references: [id])

  technicianId    String?
  technician      User?           @relation("AssignedTechnician", fields: [technicianId], references: [id])

  templateId      String?
  template        WorkOrderTemplate? @relation(fields: [templateId], references: [id])

  equipment       WorkOrderEquipment[]
  attachments     Attachment[]
  timeEntries     TimeEntry[]
}

enum WorkOrderStatus {
  ACTIVE
  COMPLETED
  PAID
}

model WorkOrderEquipment {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workOrderId String
  workOrder   WorkOrder @relation(fields: [workOrderId], references: [id])

  name        String
  quantity    Int       @default(1)

  cost        Float?
  vendor      String?
}

model Attachment {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())

  workOrderId String
  workOrder   WorkOrder @relation(fields: [workOrderId], references: [id])

  url         String
  type        String?
  description String?
}

model TimeEntry {
  id          String         @id @default(cuid())
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  workOrderId String
  workOrder   WorkOrder      @relation(fields: [workOrderId], references: [id])

  technicianId String
  technician   User          @relation(fields: [technicianId], references: [id])

  checkInAt    DateTime?
  checkInLat   Float?
  checkInLng   Float?

  checkOutAt   DateTime?
  checkOutLat  Float?
  checkOutLng  Float?

  edits        TimeEntryEdit[]
}

model TimeEntryEdit {
  id            String      @id @default(cuid())
  createdAt     DateTime    @default(now())

  timeEntryId   String
  timeEntry     TimeEntry   @relation(fields: [timeEntryId], references: [id])

  field         String
  originalValue String?
  updatedValue  String?

  editedById    String
  editedBy      User        @relation("AuditActor", fields: [editedById], references: [id])
}

model AuditLog {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  actorId   String?
  actor     User?    @relation("AuditActor", fields: [actorId], references: [id])

  entity    String
  entityId  String
  action    String
  meta      String?  // JSON
}

model Notification {
  id        String       @id @default(cuid())
  createdAt DateTime     @default(now())

  userId    String
  user      User         @relation(fields: [userId], references: [id])

  type      NotificationType
  channel   NotificationChannel

  title     String
  message   String

  deliveredAt DateTime?
  readAt      DateTime?
}

enum NotificationType {
  WORK_ORDER_ASSIGNED
  WORK_ORDER_UPDATED
  WORK_ORDER_REMINDER
  TIME_ENTRY_EDITED
}

enum NotificationChannel {
  EMAIL
  PUSH
}

