# =============================================================================
# PRISMA DATABASE CONFIGURATION
# =============================================================================
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/technician?schema=public

# Database Connection Pool Settings (optional)
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_POOL_TIMEOUT=30000

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
API_PREFIX=api/v1

APP_NAME=Technician Management System
APP_VERSION=1.0.0
TZ=UTC

# =============================================================================
# AUTHENTICATION & SECURITY
# =============================================================================
JWT_SECRET=your-jwt-secret-key-change-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your-jwt-refresh-secret-key-change-in-production
JWT_REFRESH_EXPIRES_IN=30d

BCRYPT_ROUNDS=10
PASSWORD_MIN_LENGTH=8
SESSION_SECRET=your-session-secret-change-in-production
SESSION_MAX_AGE=86400000

# =============================================================================
# PUSH NOTIFICATIONS (Firebase Cloud Messaging)
# =============================================================================
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=your-firebase-client-email
FIREBASE_PRIVATE_KEY=your-firebase-private-key
FCM_SERVER_KEY=your-fcm-server-key

# =============================================================================
# FILE STORAGE (AWS S3)
# =============================================================================
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_S3_BUCKET_NAME=your-bucket-name

MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/jpg,image/webp,application/pdf
UPLOAD_PATH=uploads

# =============================================================================
# EMAIL CONFIGURATION
# =============================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-specific-password
EMAIL_FROM=noreply@yourdomain.com
EMAIL_FROM_NAME=Technician Management System
EMAIL_TEMPLATE_DIR=templates/emails

# =============================================================================
# WORK ORDER CONFIGURATION
# =============================================================================
WORK_ORDER_REMINDER_INTERVALS=24,1
WORK_ORDER_PREFIX=WO
DEFAULT_ESTIMATED_HOURS=4

# =============================================================================
# TIME TRACKING & GPS CONFIGURATION
# =============================================================================
GPS_ACCURACY_THRESHOLD=50
TIME_ENTRY_ROUNDING_MINUTES=15

# =============================================================================
# REDIS CACHING
# =============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TTL=3600

# =============================================================================
# RATE LIMITING
# =============================================================================
THROTTLE_TTL=60
THROTTLE_LIMIT=100
RATE_LIMIT_AUTH_TTL=60
RATE_LIMIT_AUTH_LIMIT=5
RATE_LIMIT_API_TTL=60
RATE_LIMIT_API_LIMIT=100

# =============================================================================
# CORS CONFIGURATION
# =============================================================================
CORS_ORIGIN=*
CORS_CREDENTIALS=true

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================
LOG_LEVEL=debug
LOG_FORMAT=json
LOG_FILE=logs/app.log

# =============================================================================
# REPORTING & EXPORT CONFIGURATION
# =============================================================================
CSV_EXPORT_MAX_ROWS=10000
CSV_DELIMITER=,
REPORT_CACHE_TTL=3600

# =============================================================================
# ADMIN PANEL CONFIGURATION
# =============================================================================
DEFAULT_ADMIN_EMAIL=admin@technician.com
DEFAULT_ADMIN_PASSWORD=ChangeMe123!
DEFAULT_ADMIN_USERNAME=admin
ADMIN_PANEL_ENABLED=true
ADMIN_SESSION_TIMEOUT=3600000

# =============================================================================
# MOBILE APP CONFIGURATION
# =============================================================================
MOBILE_APP_VERSION_REQUIRED=1.0.0
MOBILE_FORCE_UPDATE=false

# =============================================================================
# AUDIT & COMPLIANCE
# =============================================================================
AUDIT_LOG_RETENTION_DAYS=365
AUDIT_LOGGING_ENABLED=true

# =============================================================================
# DEVELOPMENT & DEBUGGING
# =============================================================================
SWAGGER_ENABLED=true
SWAGGER_PATH=api/docs
DEBUG=false
DEBUG_SQL=false

# =============================================================================
# EXTERNAL INTEGRATIONS
# =============================================================================
PAYMENT_PROVIDER=stripe
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=

# =============================================================================
# PRODUCTION SECURITY
# =============================================================================
HELMET_ENABLED=true
TRUST_PROXY=false
HTTPS_ENABLED=false
SSL_CERT_PATH=
SSL_KEY_PATH=
